{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Federated": "<OIDC_PROVIDER_ARN>"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "<EKS_OIDC_PROVIDER>:sub": "system:serviceaccount:keda:keda-operator",
          "<EKS_OIDC_PROVIDER>:aud": "sts.amazonaws.com"
        }
      }
    }
  ]
}
